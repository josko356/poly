# ============================================================
# POLYMARKET ARBITRAGE BOT — KONFIGURACIJA
# ============================================================
# 1. Kopiraj ovaj fajl i preimenuj ga u: .env
# 2. Popuni vrijednosti ispod
# 3. NIKAD ne dijeli .env — sadrzi privatne kljuceve!
# 4. Pokreni: python scripts/check_env.py za provjeru

# ------ COINBASE DEVELOPER PLATFORM API ---------------------
# Dobis na: https://portal.cdp.coinbase.com/
# Kreiraj API key → samo View permisije → spremi oba podatka
#
# "API Key ID" s portala (dugi path, ne UUID):
COINBASE_API_KEY=organizations/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/apiKeys/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# "Secret" s portala (cijeli base64 string ukljucujuci ==):
COINBASE_API_SECRET=tvoj_base64_secret_ovdje==

# Napomena: bot radi i bez ovih kljuceva (javni WebSocket),
# ali s njima je veza stabilnija i ima bolji rate limit.

# ------ TELEGRAM OBAVIJESTI ---------------------------------
# 1. Otvori Telegram → @BotFather → /newbot → dobis token
# 2. Otvori @userinfobot → /start → dobis chat ID
# 3. Posalji /start SVOM botu — bez toga ne moze ti slati poruke!
#
# Remote komande dok bot radi: /kill /resume /status
TELEGRAM_BOT_TOKEN=123456789:ABC-tvoj_token_ovdje
TELEGRAM_CHAT_ID=987654321

# ------ PAPER TRADING ---------------------------------------
# Pocetni virtualni balans za testiranje (USDC)
PAPER_STARTING_BALANCE=1000.0

# ------ POLYGON WALLET (samo za live trading) ---------------
# Treba ti: MetaMask wallet s USDC na Polygon mrezi
#           + $1-2 POL (ex-MATIC) za gas
#
# Popuni SAMO kad prelazis na live trading!
# Provjeri kljuc s: python scripts/check_env.py
POLYGON_PRIVATE_KEY=tvoj_64_char_hex_private_key_ovdje
POLYGON_ADDRESS=0xtvoja_polygon_adresa_ovdje

# ------ LIVE TRADING (sva 3 moraju biti "true") -------------
# Ostavi false dok ne budes siguran u paper rezultate!
# Preporuka: paper trade barem tjedan dana prije.
LIVE_TRADING_ENABLED=false
LIVE_TRADING_CONFIRMED=false
LIVE_TRADING_RISK_ACKNOWLEDGED=false
